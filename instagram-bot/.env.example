# Kopiere diese Datei zu .env und trage deine Werte ein.
# .env NIE committen — die enthält dein Access Token.

# Long-Lived Access Token aus Meta Graph API Setup (siehe INSTAGRAM-SETUP.md)
IG_ACCESS_TOKEN=EAAB...

# Deine Instagram Business Account ID (17-stellige Zahl)
IG_BUSINESS_ID=17841...

# Öffentliche HTTPS-Basis-URL wo deine Videos liegen.
# Beispiele:
#   https://familienapp.de/reels
#   https://r2.deine-domain.com/instagram
# Das Skript hängt /<slug>/reel.mp4 dran.
VIDEO_PUBLIC_BASE=https://example.com/reels

# Optional: Pfad zu Chrome falls Auto-Erkennung scheitert
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Optional: Python-Befehl falls "python" nicht im PATH ist
# PYTHON=py
